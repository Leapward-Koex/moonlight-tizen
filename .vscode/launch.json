{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Moonlight: build + run on attached Tizen emulator",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\tools\\vscode-launch-emulator.ps1\"",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Moonlight: run simulated Flutter web in Chrome (profile)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}\\flutter_ui",
      "program": "${workspaceFolder}\\flutter_ui\\lib\\main_fake.dart",
      "deviceId": "chrome",
      "flutterMode": "profile"
    }
  ]
}
